## =============================================================================
## Vzaimno Backend — example environment file.
## Copy to `.env` and fill in real values. NEVER commit `.env`.
## =============================================================================
#
## --- Environment --------------------------------------------------------------
## Set to "dev" for local development, "staging" / "prod" for deployed envs.
## Controls whether the DEV_TOKEN bypass can be enabled (see ALLOW_DEV_TOKEN).
#ENV=dev
## Runtime schema bootstrap is OFF by default. Use Alembic migrations.
## Set to 1 only for legacy local bootstrap on an empty DB.
#ALLOW_RUNTIME_SCHEMA_BOOTSTRAP=0
#
## --- Database -----------------------------------------------------------------
## For local pg-docker: host=localhost, port=5433 (bound on 127.0.0.1 only).
## Password must match pg-docker/.env POSTGRES_PASSWORD.
#DATABASE_URL=postgresql://app:CHANGE_ME_STRONG_PASSWORD@localhost:5433/vzaimno
#REDIS_URL=redis://localhost:6379/0
#
## --- JWT ----------------------------------------------------------------------
## REQUIRED. Backend refuses to start if JWT_SECRET is empty or a known
## placeholder. Generate with:
##   python3 -c "import secrets; print(secrets.token_urlsafe(48))"
#JWT_SECRET=
#JWT_ALG=HS256
## Token lifetime in minutes. 10080 = 7 days (default, will be shortened once
## refresh tokens are implemented).
#JWT_EXPIRE_MINUTES=10080
#
## --- Admin JWT ----------------------------------------------------------------
## Leave empty to fall back to JWT_SECRET / JWT_ALG. In production use a
## separate secret and a shorter lifetime.
#ADMIN_JWT_SECRET=
#ADMIN_JWT_ALG=
#ADMIN_JWT_EXPIRE_MINUTES=
#ADMIN_SESSION_SECRET=
#ADMIN_SESSION_COOKIE_NAME=vzaimno_admin_session
#ADMIN_SESSION_COOKIE_SECURE=0
#ADMIN_SESSION_COOKIE_SAMESITE=lax
#ADMIN_SESSION_MAX_AGE_SECONDS=43200
#
## --- Token audiences (leave defaults) -----------------------------------------
#USER_TOKEN_AUDIENCE=user-api
#ADMIN_TOKEN_AUDIENCE=admin-api
#
## --- DEV ONLY: explicit opt-in for DEV_TOKEN bypass ---------------------------
## With ENV=dev AND ALLOW_DEV_TOKEN=1 the string "DEV_TOKEN" is accepted as a
## valid Authorization: Bearer value and logs you in as a fake user id="dev".
## NEVER set in staging or prod. Leave commented out / set to 0 by default.
## ALLOW_DEV_TOKEN=0

## --- HTTP hardening / reverse proxy ------------------------------------------
## Must contain every allowed host (api/admin domains) in prod.
#TRUSTED_HOSTS=localhost,127.0.0.1,::1
## Enable when app is behind reverse proxy (nginx/caddy/traefik).
#ENABLE_PROXY_HEADERS=0
## Which proxies are trusted for X-Forwarded-* headers.
#FORWARDED_ALLOW_IPS=127.0.0.1
## Optional CORS lists.
#CORS_ALLOWED_ORIGINS=
#ADMIN_CORS_ALLOWED_ORIGINS=
#
## --- Uploads / moderation -----------------------------------------------------
#UPLOADS_DIR=uploads
#NSFW_REVIEW=0.30
#NSFW_HARD_BLOCK=0.85
#
## --- External APIs ------------------------------------------------------------
## Yandex Routing. IMPORTANT: if this key was ever committed, ROTATE it.
## https://developer.tech.yandex.ru/services -> revoke old, issue new.
#YANDEX_ROUTING_API_KEY=
#
## Nominatim / OSM geocoding (public service, use a contact in the UA per ToS).
#NOMINATIM_URL=https://nominatim.openstreetmap.org/search
#GEOCODER_USER_AGENT=vzaimno-backend/1.0 (contact: your-email@example.com)
#
## --- Ollama (text moderation, optional) ---------------------------------------
## Set to 0 for local/dev environments where text moderation should be skipped.
#OLLAMA_ENABLED=1
## In Docker Desktop, backend containers reach host Ollama via host.docker.internal.
#OLLAMA_URL=http://host.docker.internal:11434/api/generate
#OLLAMA_TIMEOUT_S=45
#OLLAMA_RETRIES=0
## OLLAMA_MODEL=shieldgemma:2b

## --- Gemini (dispute resolution, required for dispute automation) ------------
## One model only in production dispute flow: Gemini 2.5 Flash.
#DISPUTE_GEMINI_API_KEY=
#DISPUTE_GEMINI_MODEL=gemini-2.5-flash
#DISPUTE_GEMINI_TIMEOUT_S=25
#DISPUTE_GEMINI_RETRIES=2
#DISPUTE_GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/models
#DISPUTE_GEMINI_PROMPT=
#
## --- Admin panel (optional overrides) -----------------------------------------
#ADMIN_BASE_URL=/admin
#ADMIN_TITLE=Vzaimno
