## =============================================================================
## Vzaimno Backend/Admin — production environment template.
## Copy to `.env.production` on the server and fill every required value.
## =============================================================================

## --- Runtime -----------------------------------------------------------------
ENV=prod
ENABLE_PROXY_HEADERS=1
FORWARDED_ALLOW_IPS=127.0.0.1

## Comma-separated host allowlist for both backend and admin.
## Example: api.example.com,admin.example.com
TRUSTED_HOSTS=

## --- Domains / CORS ----------------------------------------------------------
## Backend public origins (if web client exists). Mobile apps do not require CORS.
CORS_ALLOWED_ORIGINS=
## Admin web origin(s), usually your admin domain.
ADMIN_CORS_ALLOWED_ORIGINS=

## --- PostgreSQL --------------------------------------------------------------
POSTGRES_DB=vzaimno
POSTGRES_USER=vzaimno
POSTGRES_PASSWORD=
DATABASE_URL=postgresql://vzaimno:CHANGE_ME_STRONG_PASSWORD@postgres:5432/vzaimno

## --- Redis (required in prod for auth rate limiting / readiness) ------------
REDIS_URL=redis://redis:6379/0

## --- JWT / Sessions (required) -----------------------------------------------
## Generate each with:
##   python3 -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=
ADMIN_JWT_SECRET=
ADMIN_SESSION_SECRET=
JWT_ALG=HS256
ADMIN_JWT_ALG=HS256
JWT_EXPIRE_MINUTES=10080
ADMIN_JWT_EXPIRE_MINUTES=60
ADMIN_SESSION_COOKIE_NAME=vzaimno_admin_session
ADMIN_SESSION_COOKIE_SECURE=1
ADMIN_SESSION_COOKIE_SAMESITE=lax
ADMIN_SESSION_MAX_AGE_SECONDS=43200

## --- Cryptographic keys used by app/migrations (required) --------------------
IP_HASH_KEY=
PII_ENCRYPTION_KEY=
PHONE_HASH_KEY=

## --- Uploads -----------------------------------------------------------------
UPLOADS_DIR=/app/uploads
STORAGE_BACKEND=local
## S3 mode (required if STORAGE_BACKEND=s3)
#S3_ENDPOINT_URL=
#S3_ACCESS_KEY=
#S3_SECRET_KEY=
#S3_REGION=us-east-1
#S3_BUCKET=vzaimno-uploads
#S3_PRESIGNED_EXPIRES_SECONDS=900
#S3_PRESIGNED_EXPIRES_SECONDS_MAX=3600

## --- External APIs ------------------------------------------------------------
YANDEX_ROUTING_API_KEY=
NOMINATIM_URL=https://nominatim.openstreetmap.org/search
GEOCODER_USER_AGENT=vzaimno-backend/1.0 (contact: ops@example.com)

## Dispute automation (if used in production)
DISPUTE_GROQ_API_KEY=
DISPUTE_GROQ_MODEL=llama-3.1-8b-instant
DISPUTE_GROQ_TIMEOUT_S=25
DISPUTE_GROQ_RETRIES=2
DISPUTE_GROQ_BASE_URL=https://api.groq.com/openai/v1

## --- Optional bootstrap admin account ----------------------------------------
## Used only when admin_accounts table is empty.
#ADMIN_BOOTSTRAP_LOGIN=
#ADMIN_BOOTSTRAP_PASSWORD=
#ADMIN_BOOTSTRAP_DISPLAY_NAME=Super Admin
